pipeline {
    agent any

    environment {
        AWS_ACCESS_KEY_ID = credentials('aws-access-key')
        AWS_SECRET_ACCESS_KEY = credentials('aws-secret-key')
        AWS_DEFAULT_REGION = 'us-west-1'
    }

    stages {
        stage('init') {
            steps {
                sh 'terraform init'
            }
        }

        stage('plan') {
            steps {
                sh 'terraform plan'
            }
        }

        stage('apply') {
            steps {
                sh 'terraform apply -auto-approve'
            }
        }
    }
}
