pipeline {
    agent any

    environment {
        AWS_ACCESS_KEY_ID = credentials('aws-access-key')
        AWS_SECRET_ACCESS_KEY = credentials('aws-secret-key')
        AWS_DEFAULT_REGION = 'ap-south-1'
    }

    stages {
        stage('init') {
            steps {
                dir('Terraform1') {
                    sh 'terraform init'
                }
            }
        }

        stage('plan') {
            steps {
                dir('Terraform1') {
                    sh 'terraform plan'
                }
            }
        }

        stage('apply') {
            steps {
                dir('Terraform1') {
                    sh 'terraform apply -auto-approve'
                }
            }
        }
    }
}
